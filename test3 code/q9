# creating book table and inserting data

CREATE TABLE Book (
    BookID INT PRIMARY KEY,
    BookName VARCHAR(100),
    Author VARCHAR(100),
    Price INT
);
INSERT INTO Book VALUES
(1, 'Python Basics', 'John', 500),
(2, 'Learning SQL', 'David', 700);

1.Creating Stored Procedure and Executing

DELIMITER $$

CREATE PROCEDURE GetBooks()
BEGIN
    SELECT * FROM Book;
END $$

DELIMITER ;

CALL GetBooks();