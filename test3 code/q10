# Creating Student and Course tables and inserting data

CREATE TABLE Student (
    StudentID INT PRIMARY KEY,
    Name VARCHAR(100),
    CourseID INT
);
INSERT INTO Student VALUES
(1, 'Rahul', 101),
(2, 'Neha', 102),
(3, 'Aman', 101);

CREATE TABLE Course (
    CourseID INT PRIMARY KEY,
    CourseName VARCHAR(100)
);
INSERT INTO Course VALUES
(101, 'Python'),
(102, 'Java');

1. Display Student Name and Course Name using INNER JOIN

SELECT Student.Name,
       Course.CourseName
FROM Student
INNER JOIN Course
ON Student.CourseID = Course.CourseID;


2. Display only students enrolled in Python

SELECT Student.Name,
       Course.CourseName
FROM Student
INNER JOIN Course
ON Student.CourseID = Course.CourseID
WHERE Course.CourseName = 'Python';


3. Create View PythonStudents

CREATE VIEW PythonStudents AS
SELECT Student.Name,
       Course.CourseName
FROM Student
INNER JOIN Course
ON Student.CourseID = Course.CourseID
WHERE Course.CourseName = 'Python';