
# 4. Rank Participants
# A sports academy has recorded the timings (in seconds) of participants in
# a race.
# Write a program to arrange the timings from the fastest to the slowest so
# that the winners can be announced.
def selection_sort(timings):
    n = len(timings)

    for i in range(n - 1):                      
        min_index = i                            

        for j in range(i + 1, n):               
            if timings[j] < timings[min_index]:
                min_index = j                    

        if min_index != i:
            timings[i], timings[min_index] = timings[min_index], timings[i]

    return timings
n = int(input("Enter number of participants: "))

names    = []
timings  = []

for i in range(n):
    name   = input(f"\nEnter name of participant {i + 1}: ")
    timing = float(input(f"Enter timing of {name} (in seconds): "))
    names.append(name)
    timings.append(timing)


combined = list(zip(timings, names))      

for i in range(len(combined) - 1):
    min_index = i
    for j in range(i + 1, len(combined)):
        if combined[j][0] < combined[min_index][0]:
            min_index = j
    combined[i], combined[min_index] = combined[min_index], combined[i]

print("\n--- Race Results (Fastest to Slowest) ---")
print(f"{'Rank':<6} {'Name':<15} {'Time (s)'}")
print("-" * 32)
for rank, (time, name) in enumerate(combined, start=1):
    print(f"{rank:<6} {name:<15} {time}")